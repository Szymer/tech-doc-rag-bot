{
  "name": "control-cabinet-rag",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/control-cabinet-rag",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/control-cabinet-rag/.venv/bin/python"
      }
    }
  },
  "postCreateCommand": "/home/vscode/.local/bin/uv sync",
  "remoteUser": "vscode"
}